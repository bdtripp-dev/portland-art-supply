{
  "name": "Portland Art Supply Dev",
  "dockerComposeFile": [
    "../docker-compose.yaml",
    "../docker-compose.override.yaml"
  ],
  "service": "portland-art-supply",
  "workspaceFolder": "/workspaces/portland-art-supply",
  "customizations": {
    "vscode": {
      "extensions": ["xdebug.php-debug"]
    }
  },
  "remoteUser": "root",
  "overrideCommand": false,
  "remoteEnv": {
    "VSCODE_AGENT_FOLDER": "/root/.vscode-server"
  }
}
